---
import { cn } from '@lib/utils';
import { Image } from 'astro:assets';
import halilJpg from '/public/halil.jpg';

const { class: otherClasses = '', ...rest } = Astro.props;
---

<Image
  src={halilJpg}
  alt="Halil"
  class={cn('rounded-full border-2 border-stone-300 dark:border-stone-600 ', otherClasses)}
  {...rest}
/>
